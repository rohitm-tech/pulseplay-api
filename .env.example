PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/pulseplay
JWT_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CRIC_API_KEY=
CRIC_API_BASE=https://api.cricapi.com/v1
# Optional: shared Mongo cache TTLs (ms). Defaults: 5 days — demo/hackathon friendly if CricAPI is down or capped.
# CRIC_CACHE_MATCH_SUMMARY_TTL_MS=432000000
# CRIC_CACHE_COMMENTARY_TTL_MS=432000000
CLIENT_URL=http://localhost:3000
LIVE_POLL_INTERVAL_MS=45000

# Gemini — required for /api/ai (summaries, highlights, insights; same stack as HackAIBengaluru)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Optional: per-request ceiling (ms) so fan-desk can fall back if Gemini hangs. Default 25000.
# GEMINI_REQUEST_TIMEOUT_MS=25000
